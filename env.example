# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Mercado Pago Configuration
VITE_MERCADOPAGO_ACCESS_TOKEN=TEST-your_access_token
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-your_public_key

# iFood Configuration
VITE_IFOOD_CLIENT_ID=your_ifood_client_id
VITE_IFOOD_CLIENT_SECRET=your_ifood_client_secret
VITE_IFOOD_USERNAME=your_ifood_username
VITE_IFOOD_PASSWORD=your_ifood_password

# Serverless Functions (Vercel)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Private Key Here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com

# Mercado Pago (Serverless)
MERCADOPAGO_ACCESS_TOKEN=TEST-your_access_token

# iFood (Serverless)
IFOOD_CLIENT_ID=your_ifood_client_id
IFOOD_CLIENT_SECRET=your_ifood_client_secret

# Development
VITE_DEV_MODE=true 